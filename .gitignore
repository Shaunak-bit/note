# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Backend specific
backend/node_modules/
backend/dist/
backend/src/generated/
backend/*.log

# Docker
.dockerignore

# Database files
*.db
*.sqlite
*.sqlite3

# Logs
logs/
*.log

# OS files
Thumbs.db
ehthumbs.db
